# Copy this file to .env and fill in one backend.

# Option A: DeepSeek via OpenAI-compatible API
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=4096

# Option B: Google AI Studio
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=your_google_ai_studio_key

# Option C: Vertex AI
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ------------------------------------------------------------------
# Discord bot (via ADK Connector)
# ------------------------------------------------------------------
# 1. Create a Discord app at https://discord.com/developers/applications
# 2. Go to Bot → Reset Token → copy the token below
DISCORD_BOT_TOKEN=your_discord_bot_token
# 3. Enable Developer Mode in Discord → right-click your username → Copy ID
#    Paste it here to sync your Discord chats with the `adk web` UI
DISCORD_USER_ID=your_discord_user_id
