# Never put real credentials in this file. Copy it to .env for local use.

# Production owner authentication: SHA-256 of the plaintext owner access key.
PKM_OWNER_ID=owner
PKM_API_KEY_HASH=

# Production per-record keys live off-VM in a dedicated OCI Object Storage
# bucket with versioning disabled and no retention rule. The VM uses its
# instance principal; do not put an OCI user API key here.
REGULATION_RECORD_KEY_PROVIDER=oci
OCI_RECORD_KEY_NAMESPACE=
OCI_RECORD_KEY_BUCKET=
OCI_RECORD_KEY_PREFIX=pkm-record-keys/

# Legacy migration only. New production records do not use a VM master key.
REGULATION_KEY_PATH=
# REGULATION_KEY=<64 lowercase hex characters; local development/migration only>
PKM_DATA_DIR=data
AUDIT_LOG_DIR=data/audit

# OpenAI is optional. Without it, deterministic Regulation fallback remains available.
OPENAI_API_KEY=
OPENAI_GPT5_MINI_MODEL=gpt-5-mini
OPENAI_GPT5_MODEL=gpt-5

# Same-origin production needs no CORS origin. Local Vite defaults to localhost:5173.
CORS_ORIGINS=

# Optional Discord integration.
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=
